# Business Contact Info
VITE_BUSINESS_PHONE="2144332703"
VITE_BUSINESS_EMAIL="info@broomandbox.com"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Admin Authentication (REQUIRED - server will not start without these!)
# JWT_SECRET: Random secret for signing tokens (generate with: openssl rand -base64 32)
JWT_SECRET="change-this-to-a-random-secret-in-production"
# ADMIN_USERNAME: Admin portal username (REQUIRED)
ADMIN_USERNAME="admin"
# ADMIN_PASSWORD: Admin portal password (REQUIRED)
ADMIN_PASSWORD="change-this-secure-password"

# CORS Configuration (production)
# ALLOWED_ORIGINS: Comma-separated list of allowed origins (e.g., https://yourdomain.com)
ALLOWED_ORIGINS="http://localhost:3000"

# Supabase Configuration
# SUPABASE_URL: Your project URL (https://<project-id>.supabase.co)
SUPABASE_URL="https://your-project-id.supabase.co"
# SUPABASE_ANON_KEY: Public/publishable key (sb_publishable_...)
SUPABASE_ANON_KEY="sb_publishable_..."
# SUPABASE_SERVICE_ROLE_KEY: Secret key — never expose client-side (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Hostinger SMTP Configuration (for email notifications)
# SMTP_USER: Your Hostinger business email (e.g. info@yourdomain.com)
SMTP_USER="info@broomandbox.com"
# SMTP_PASSWORD: Your Hostinger email account password
SMTP_PASSWORD="your-hostinger-email-password"
